GEMINI_API_KEY=your-gemini-api-key
UNIPILE_API_KEY=
UNIPILE_BASE_URL=https://api.unipile.com/v2
# Optional fallbacks. Normally sender accounts are resolved from the signed-in user's email/phone.
UNIPILE_WHATSAPP_ACCOUNT_ID=
UNIPILE_EMAIL_ACCOUNT_ID=
UNIPILE_ENABLE_SENDS=true
DATABASE_URL=postgresql://warmleads:warmleads@localhost:5433/warmleads
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
EMBED_DIM=1536
AREA_CACHE_TTL_DAYS=30
MAX_BUYERS_PER_RESEARCH=12
GEOCODE_USE_NOMINATIM=true
