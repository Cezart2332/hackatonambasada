generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  PRODUCER
  VENUE
  ADMIN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionTier {
  FREE
  PRO
}

model User {
  id              String           @id @default(cuid())
  name            String
  email           String           @unique
  emailVerified   Boolean          @default(false)
  image           String?
  accountType     AccountType      @default(PRODUCER)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  sessions        Session[]
  accounts        Account[]
  producerProfile ProducerProfile?
  venueProfile              VenueProfile?
  leadStatuses              LeadStatusRecord[]
  producerMatchStatuses     ProducerMatchStatusRecord[]
  venueLeadStatuses         VenueLeadStatusRecord[] @relation("VenueLeadTargets")
  usageQuotas               UsageQuota[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

enum LeadIcon {
  restaurant
  hotel
  cafe
  shop
  deli
}

enum LeadStatus {
  BUN
  NU_E_POTRIVIT
  CONTACTAT
  A_RASPUNS
  A_CUMPARAT
}

model ProducerProfile {
  id             String            @id @default(cuid())
  userId         String            @unique
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName   String            @default("")
  phone          String            @default("")
  location       String            @default("")
  locationChoice String?
  latitude       Float?
  longitude      Float?
  rangeKm        Float             @default(35)
  deliveryDays   String            @default("")
  extraDetails       String            @default("")
  approvalStatus     ApprovalStatus    @default(PENDING)
  verified           Boolean           @default(false)
  subscriptionTier   SubscriptionTier  @default(FREE)
  proActivatedAt     DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  products           ProducerProduct[]

  @@map("producer_profile")
}

model UsageQuota {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekKey     String
  discoveries Int      @default(0)
  simulations Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, weekKey])
  @@map("usage_quota")
}

model VenueProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName    String   @default("")
  venueType       LeadIcon @default(restaurant)
  phone           String   @default("")
  location        String   @default("")
  locationChoice  String?
  latitude        Float?
  longitude       Float?
  approvalStatus  ApprovalStatus @default(PENDING)
  productsNeeded  String         @default("")
  supplyFrequency String         @default("")
  preferredDays   String         @default("")
  needsUpdatedAt  DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  searchHistory   VenueSearchHistory[]

  @@map("venue_profile")
}

model VenueSearchHistory {
  id              String       @id @default(cuid())
  venueUserId     String
  venueProfile    VenueProfile @relation(fields: [venueUserId], references: [userId], onDelete: Cascade)
  productsNeeded  String       @default("")
  supplyFrequency String       @default("")
  preferredDays   String       @default("")
  createdAt       DateTime     @default(now())

  @@index([venueUserId, createdAt])
  @@map("venue_search_history")
}

model ProducerProduct {
  id                String          @id @default(cuid())
  profileId         String
  profile           ProducerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name              String
  estimatedQuantity String          @default("")
  unit              String          @default("kg")
  pricePerKg        String          @default("")
  availableFrom     String          @default("Saptamana asta")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("producer_product")
}

model Lead {
  id        String     @id
  name      String
  type      String
  location  String
  latitude  Float
  longitude Float
  baseMatch Int
  reason    String
  sell      String
  bestDay   String
  contact   String
  tone      String
  icon      LeadIcon
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  statuses  LeadStatusRecord[]

  @@map("lead")
}

model ProducerMatchStatusRecord {
  id             String     @id @default(cuid())
  producerUserId String
  venueUserId    String
  venueUser      User       @relation(fields: [venueUserId], references: [id], onDelete: Cascade)
  status         LeadStatus
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([producerUserId, venueUserId])
  @@map("producer_match_status_record")
}

model VenueLeadStatusRecord {
  id             String     @id @default(cuid())
  producerUserId String
  venueUserId    String
  venueUser      User       @relation("VenueLeadTargets", fields: [venueUserId], references: [id], onDelete: Cascade)
  status         LeadStatus
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([producerUserId, venueUserId])
  @@map("venue_lead_status_record")
}

model LeadStatusRecord {
  id        String     @id @default(cuid())
  leadId    String
  lead      Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    LeadStatus
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([leadId, userId])
  @@map("lead_status_record")
}

model DirectConversation {
  id             String   @id @default(cuid())
  producerUserId String
  venueUserId    String
  lastMessageAt  DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  messages       DirectMessage[]
  reads          DirectConversationRead[]

  @@unique([producerUserId, venueUserId])
  @@map("direct_conversation")
}

model DirectMessage {
  id             String             @id @default(cuid())
  conversationId String
  conversation   DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUserId   String
  body           String
  createdAt      DateTime           @default(now())

  @@index([conversationId, createdAt])
  @@map("direct_message")
}

model DirectConversationRead {
  id             String             @id @default(cuid())
  conversationId String
  conversation   DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  lastReadAt     DateTime           @default(now())

  @@unique([conversationId, userId])
  @@map("direct_conversation_read")
}
