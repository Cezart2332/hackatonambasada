# =============================================================================
# Warm Leads — project environment (copy to .env and fill in secrets)
# =============================================================================
# Docker Compose loads this file for all services.
# For local dev without Docker, use the Local dev values noted in comments.

# --- Postgres (db service) ---
POSTGRES_USER=warmleads
POSTGRES_PASSWORD=warmleads
POSTGRES_DB=warmleads

# --- Backend (Node / Express) ---
APP_URL=http://backend:3001
INTERNAL_API_TOKEN=
# Docker: host db, port 5432 inside the network
DATABASE_URL=postgresql://warmleads:warmleads@db:5432/warmleads?schema=public
# Local dev: postgresql://warmleads:warmleads@localhost:5433/warmleads?schema=public

PORT=3001
FRONTEND_URL=http://localhost:5173
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_SECRET=dev-secret-change-me-use-openssl-rand-base64-32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Docker: internal AI service hostname
AI_SERVICE_URL=http://ai:8000
# Local dev: http://localhost:8000

# --- AI service (FastAPI / Gemini) ---
GEMINI_API_KEY=
UNIPILE_API_KEY=
UNIPILE_WEBHOOK_SECRET=
# Public tunnel URL from docker compose logs cloudflared (trycloudflare.com)
CLOUDFLARE_TUNNEL_URL=
UNIPILE_BASE_URL=https://api.unipile.com/v2
# Optional fallbacks. Normally the app resolves sender accounts from the signed-in user's email/phone.
UNIPILE_WHATSAPP_ACCOUNT_ID=
UNIPILE_EMAIL_ACCOUNT_ID=
UNIPILE_ENABLE_SENDS=true

GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
EMBED_DIM=1536
AREA_CACHE_TTL_DAYS=30
MAX_BUYERS_PER_RESEARCH=12
GEOCODE_USE_NOMINATIM=true

# --- Frontend (Vite dev in Docker) ---
VITE_PROXY_TARGET=http://backend:3001
# Local dev: http://localhost:3001
